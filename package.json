{
  "name": "pdf-health-check",
  "version": "1.1.0",
  "description": "PDF Health Check App using Adobe PDF Services API",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "release": "electron-builder --mac --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.4"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.0",
    "electron": "^28.3.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.pdfhealthcheck.app",
    "productName": "PDF Health Check",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "paulvandelft992",
      "repo": "pdf-health-check",
      "private": true
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": {
        "teamId": "F5HD4RNX7P"
      },
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": ["nsis"]
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*"
    ]
  }
}
